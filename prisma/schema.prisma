generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}


model Category {
  id       Int       @id @default(autoincrement())
  name     String
  order    Int       @default(0)
  sections Section[]
}

model Section {
  id         Int      @id @default(autoincrement())
  name       String
  order      Int      @default(0)
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId Int
  posts      Post[]
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  order     Int     @default(0)
  published Boolean @default(false)
  section   Section @relation(fields: [sectionId], references: [id])
  sectionId Int
} 